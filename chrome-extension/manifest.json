{
  "manifest_version": 3,
  "name": "Devin Hackathon",
  "version": "1.0",
  "description": "Devin Hackathon",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/feed/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
